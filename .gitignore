# Root level gitignore for BarberConnect project

# Environment variables (NEVER commit these!)
.env
.env.local
.env.development
.env.test
.env.production
.env.staging
.vscode

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp
.cache/

# Security and sensitive files
*.key
*.pem
*.p12
*.jks
secrets/
credentials/
serviceAccountKey.json

# Documentation build
docs/_build/

# Project specific
mobile/node_modules/
mobile/build/
mobile/dist/

# Backup files
*.bak
*.backup

# ======== Android / Mobile App ========
mobile/.gradle/
mobile/app/build/
mobile/build/
mobile/local.properties
mobile/**/*.apk
mobile/**/*.ap_
mobile/**/*.aab
mobile/**/*.dex
mobile/**/*.class
mobile/google-services.json

# ======== Spring Boot / Backend ========
backend/target/
backend/.mvn/
backend/mvnw
backend/mvnw.cmd
backend/**/*.class
backend/**/*.jar
backend/**/*.war

# IDE files
*.iml
.idea/
.vscode/