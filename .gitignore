.env.development
.env.test
.env.production
.env.staging
.vscode

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp
.cache/

