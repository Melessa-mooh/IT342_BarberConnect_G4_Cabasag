*.key
*.pem
*.p12
*.jks
secrets/
credentials/
serviceAccountKey.json
google-services.json

# Documentation build
docs/_build/

# Project specific
mobile/node_modules/
mobile/build/
mobile/dist/

# Backup files
*.bak
*.backup