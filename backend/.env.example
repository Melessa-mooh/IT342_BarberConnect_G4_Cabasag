# Example backend .env
# Copy this file to .env and fill with real values (do NOT commit secrets)

DATABASE_URL=jdbc:postgresql://db.example.supabase.co:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# Supabase JWT secret (from Supabase Dashboard > Settings > API)
SUPABASE_JWT_SECRET=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXX

# Spring Boot options (optional)
SPRING_PROFILES_ACTIVE=local
