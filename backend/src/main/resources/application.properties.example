# Example application properties file
# Copy this to application.properties and update with your actual values

# Application Configuration
spring.application.name=barberconnect-backend

# Server Configuration
server.port=8080
server.servlet.context-path=/api/v1

# Firebase Configuration (Firestore ONLY - no auth)
firebase.service-account-key=classpath:serviceAccountKey.json
firebase.project.id=your-firebase-project-id

# Google OAuth2 Configuration - REPLACE WITH YOUR VALUES
spring.security.oauth2.client.registration.google.client-id=your-google-client-id-here
spring.security.oauth2.client.registration.google.client-secret=your-google-client-secret-here
spring.security.oauth2.client.registration.google.scope=profile,email
spring.security.oauth2.client.registration.google.redirect-uri={baseUrl}/login/oauth2/code/google

# OAuth2 Provider Configuration
spring.security.oauth2.client.provider.google.authorization-uri=https://accounts.google.com/o/oauth2/auth
spring.security.oauth2.client.provider.google.token-uri=https://oauth2.googleapis.com/token
spring.security.oauth2.client.provider.google.user-info-uri=https://www.googleapis.com/oauth2/v2/userinfo
spring.security.oauth2.client.provider.google.user-name-attribute=email

# JWT Configuration - REPLACE WITH SECURE SECRET
jwt.secret=your-secure-jwt-secret-key-minimum-256-bits
jwt.expiration=86400000

# Cloudinary Configuration - REPLACE WITH YOUR VALUES
cloudinary.cloud-name=your-cloud-name
cloudinary.api-key=your-api-key
cloudinary.api-secret=your-api-secret

# CORS Configuration
cors.allowed-origins=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000

# Frontend URL for OAuth2 redirect
frontend.url=http://localhost:5173

# Logging
logging.level.edu.cit.cabasag.barberconnect=DEBUG
logging.level.org.springframework.security=DEBUG