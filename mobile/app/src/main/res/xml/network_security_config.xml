<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows cleartext (HTTP) traffic to the development backend.
    This is safe for debug builds only. In production use HTTPS.
-->
<network-security-config>
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
    <!-- Allow cleartext for local development server on real device.
         Only needs BASE_URL in build.gradle.kts updated — no change needed here. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
