<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mobile_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/headerBar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/white"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_scissors" />

            <TextView
                android:id="@+id/tvHeaderBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="BarberConnect"
                android:textColor="@color/navy_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDashboardSearch"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@color/input_bg"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="6dp"
                android:hint="Search barbers or styles..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:paddingHorizontal="10dp"
                android:textColor="@color/gray_text_dark"
                android:textColorHint="@color/gray_text_light"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnMenu"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@color/input_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="☰"
                android:textColor="@color/navy_dark"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/welcomeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:strokeColor="@color/gray_border_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvAvatar"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:gravity="center"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvWelcome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/navy_dark"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:textColor="@color/gray_text"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvRole"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@color/orange_soft"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="5dp"
                                android:textColor="@color/orange_dark"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/customerHomeContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:strokeColor="@color/gray_border_soft"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvDashboardTitle"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Barber Feed"
                                        android:textColor="@color/navy_dark"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvDashboardSubtitle"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="3dp"
                                        android:text="Latest posts from all barbers"
                                        android:textColor="@color/gray_text"
                                        android:textSize="13sp" />
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/btnSeeAllFeed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="36dp"
                                    android:background="@color/orange_soft"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:gravity="center"
                                    android:paddingHorizontal="12dp"
                                    android:text="See all"
                                    android:textColor="@color/orange_dark"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <ProgressBar
                                android:id="@+id/progressFeed"
                                style="?android:attr/progressBarStyleSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="16dp"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvFeedEmpty"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:gravity="center"
                                android:padding="18dp"
                                android:text="No posts yet. Check back soon!"
                                android:textColor="@color/gray_text"
                                android:textSize="13sp"
                                android:visibility="gone" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/recyclerDashboardPosts"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:nestedScrollingEnabled="false"
                                android:overScrollMode="never" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:strokeColor="@color/gray_border_soft"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Available Barbers"
                                        android:textColor="@color/navy_dark"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvBarbersCount"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="3dp"
                                        android:text="Finding barbers near you"
                                        android:textColor="@color/gray_text"
                                        android:textSize="13sp" />
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/btnSeeAllBarbers"
                                    android:layout_width="wrap_content"
                                    android:layout_height="36dp"
                                    android:background="@color/orange_soft"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:gravity="center"
                                    android:paddingHorizontal="12dp"
                                    android:text="See all"
                                    android:textColor="@color/orange_dark"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <ProgressBar
                                android:id="@+id/progressBarbers"
                                style="?android:attr/progressBarStyleSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="16dp"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvBarbersEmpty"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:gravity="center"
                                android:padding="18dp"
                                android:text="No barbers available right now."
                                android:textColor="@color/gray_text"
                                android:textSize="13sp"
                                android:visibility="gone" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/recyclerDashboardBarbers"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:nestedScrollingEnabled="false"
                                android:overScrollMode="never" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="18dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:strokeColor="@color/gray_border_soft"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="My Appointments"
                                        android:textColor="@color/navy_dark"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvSelectedDate"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="3dp"
                                        android:textColor="@color/gray_text"
                                        android:textSize="13sp" />
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/btnSeeAllAppointments"
                                    android:layout_width="wrap_content"
                                    android:layout_height="36dp"
                                    android:background="@color/orange_soft"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:gravity="center"
                                    android:paddingHorizontal="12dp"
                                    android:text="Details"
                                    android:textColor="@color/orange_dark"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <CalendarView
                                android:id="@+id/calendarDashboard"
                                android:layout_width="match_parent"
                                android:layout_height="300dp"
                                android:layout_marginTop="8dp"
                                android:dateTextAppearance="@style/DashboardCalendarDateText"
                                android:focusedMonthDateColor="@color/navy_dark"
                                android:selectedWeekBackgroundColor="@color/orange_soft"
                                android:showWeekNumber="false"
                                android:unfocusedMonthDateColor="@color/gray_text_light"
                                android:weekSeparatorLineColor="@color/gray_border_soft"
                                android:weekDayTextAppearance="@style/DashboardCalendarWeekText" />

                            <ProgressBar
                                android:id="@+id/progressAppointments"
                                style="?android:attr/progressBarStyleSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="16dp"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvAppointmentsEmpty"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:gravity="center"
                                android:padding="18dp"
                                android:text="No appointments for this date."
                                android:textColor="@color/gray_text"
                                android:textSize="13sp"
                                android:visibility="gone" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/recyclerDashboardAppointments"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:nestedScrollingEnabled="false"
                                android:overScrollMode="never" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dashboardMenuContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDashboardTitleLegacy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:text="Overview"
                        android:textColor="@color/navy_dark"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDashboardSubtitleLegacy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Your mobile dashboard"
                        android:textColor="@color/gray_text"
                        android:textSize="14sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/tvPrimaryIcon"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@color/orange_accent"
                                android:gravity="center"
                                android:text="1"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvPrimaryTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/navy_dark"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvPrimarySubtitle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:textColor="@color/gray_text"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="@color/orange_accent"
                                android:textSize="30sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardSecondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp">

                        <TextView
                            android:id="@+id/tvSecondaryTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="18dp"
                            android:textColor="@color/navy_dark"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardTertiary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp">

                        <TextView
                            android:id="@+id/tvTertiaryTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="18dp"
                            android:textColor="@color/navy_dark"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQuaternary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:visibility="gone"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp">

                        <TextView
                            android:id="@+id/tvQuaternaryTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="18dp"
                            android:textColor="@color/navy_dark"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <View
        android:id="@+id/drawerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:clickable="true"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/drawerPanel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/white"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="18dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDrawerTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Menu"
                android:textColor="@color/navy_dark"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCloseDrawer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="×"
                android:textColor="@color/navy_dark"
                android:textSize="28sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/drawerItem1"
            style="@style/DrawerItemStyle" />
        <TextView
            android:id="@+id/drawerItem2"
            style="@style/DrawerItemStyle" />
        <TextView
            android:id="@+id/drawerItem3"
            style="@style/DrawerItemStyle" />
        <TextView
            android:id="@+id/drawerItem4"
            style="@style/DrawerItemStyle" />
        <TextView
            android:id="@+id/drawerItem5"
            style="@style/DrawerItemStyle"
            android:visibility="gone" />
        <TextView
            android:id="@+id/drawerItem6"
            style="@style/DrawerItemStyle"
            android:visibility="gone" />
        <TextView
            android:id="@+id/drawerItem7"
            style="@style/DrawerItemStyle"
            android:visibility="gone" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/BarberConnectButton.Outlined"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Sign Out" />
    </LinearLayout>
</FrameLayout>
