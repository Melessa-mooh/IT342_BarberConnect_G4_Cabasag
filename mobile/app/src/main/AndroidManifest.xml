<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".BarberConnectApp"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BarberConnect"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- ── Entry point ──────────────────────────────────────────────── -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.BarberConnect.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Auth ─────────────────────────────────────────────────────── -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.LandingActivity"
            android:exported="false" />

        <activity
            android:name=".ui.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── Dashboard (role-aware) ────────────────────────────────────── -->
        <activity
            android:name=".ui.DashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.DashboardActivity" />

        <!-- ── Customer screens ─────────────────────────────────────────── -->
        <activity
            android:name=".ui.customer.CustomerBarberListActivity"
            android:exported="false"
            android:parentActivityName=".ui.DashboardActivity" />

        <activity
            android:name=".ui.customer.BookingActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.customer.CustomerBarberListActivity" />

        <activity
            android:name=".ui.customer.MyAppointmentsActivity"
            android:exported="false"
            android:parentActivityName=".ui.DashboardActivity" />

        <activity
            android:name=".ui.customer.BarberFeedActivity"
            android:exported="false"
            android:parentActivityName=".ui.DashboardActivity" />

        <!-- ── Barber screens ────────────────────────────────────────────── -->
        <activity
            android:name=".ui.barber.BarberScheduleActivity"
            android:exported="false"
            android:parentActivityName=".ui.DashboardActivity" />

        <activity
            android:name=".ui.barber.BarberCatalogActivity"
            android:exported="false"
            android:parentActivityName=".ui.DashboardActivity" />

        <activity
            android:name=".ui.barber.BarberLeaveActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.DashboardActivity" />

        <activity
            android:name=".ui.barber.BarberIncomeActivity"
            android:exported="false"
            android:parentActivityName=".ui.DashboardActivity" />

        <activity
            android:name=".ui.barber.BarberFeedActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ui.DashboardActivity" />

    </application>

</manifest>
